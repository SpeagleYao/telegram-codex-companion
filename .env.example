TELEGRAM_BOT_TOKEN=123456:replace-me
ALLOWED_USER_IDS=123456789
PROJECTS_STORAGE_PATH=./data/projects.sqlite
STATE_STORAGE_PATH=./data/state.sqlite

# Codex CLI command or absolute path. On Windows, a quoted codex.cmd path is allowed if needed.
CODEX_EXECUTABLE=codex
CODEX_FULL_AUTO=true
# Optional sandbox mode passed to Codex as --sandbox <value>. Leave blank to use Codex CLI defaults.
CODEX_SANDBOX=workspace-write
# Optional exact model id passed to Codex as --model <value>. Leave blank to use the Codex CLI default model.
CODEX_MODEL=
# Optional reasoning effort override passed as model_reasoning_effort. Common values are low, medium, and high.
CODEX_REASONING_EFFORT=high
DEFAULT_PROJECT_ROOT=
# Local debug logging is off by default. Enable only for temporary local troubleshooting.
DEBUG_LOG_ENABLED=false
# JSONL file path used when DEBUG_LOG_ENABLED=true.
DEBUG_LOG_PATH=./logs/bot-debug.jsonl
DEFAULT_REPLY_CHUNK_SIZE=3500
POLL_TIMEOUT_SECONDS=20
POLL_RETRY_DELAY_MS=3000
